# Copy this file to `.env.local` and fill in your Supabase project values.
# Find them in: Supabase Dashboard → Project Settings → Data API (or API).
# The anon key is a public client key — it's safe to ship; Row-Level Security
# keeps each user's data private.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
